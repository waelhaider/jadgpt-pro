{
  "entities": {
    "Post": {
      "title": "Post",
      "description": "A post containing an image and text, part of a specific board.",
      "type": "object",
      "properties": {
        "text": {
          "type": "string",
          "description": "The textual content of the post."
        },
        "imageUrl": {
          "type": "string",
          "format": "uri",
          "description": "An image URL."
        },
        "imageUrls": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Multiple image URLs."
        },
        "boardId": {
          "type": "string",
          "description": "The ID of the board this post belongs to."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the post was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the post was last updated."
        },
        "authorId": {
          "type": "string",
          "description": "The UID of the admin."
        },
        "authorEmail": {
          "type": "string",
          "description": "The email of the admin."
        }
      },
      "required": ["text", "boardId", "createdAt", "authorId"]
    },
    "Board": {
      "title": "Board",
      "description": "A category or collection of posts.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The display name of the board."
        },
        "order": {
          "type": "number",
          "description": "The display order of the board."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp."
        }
      },
      "required": ["name", "order", "createdAt"]
    }
  },
  "firestore": {
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Collection for all posts."
    },
    "/boards/{boardId}": {
      "schema": "Board",
      "description": "Collection for categories/boards."
    }
  }
}
