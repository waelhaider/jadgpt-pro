rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
             request.auth.token.email.lower() == 'alwaelai2000@gmail.com' ||
             (exists(/databases/$(database)/documents/settings/global) && get(/databases/$(database)/documents/settings/global).data.ownerEmail.lower() == request.auth.token.email.lower())
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    function isValidBoard(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.order is number &&
             (data.get('locked', false) is bool) &&
             data.keys().hasAll(['name', 'order', 'createdAt']);
    }

    function isValidBoardUpdate(data) {
      return (data.get('name', '') is string && data.get('name', '').size() > 0) ||
             (data.get('order', 0) is number) ||
             (data.get('locked', false) is bool);
    }

    function isValidPost(data) {
      return data.text is string && data.text.size() <= 5000 &&
             (data.get('imageUrl', null) == null || data.get('imageUrl', null) is string) &&
             (data.get('imageUrls', []) is list && data.get('imageUrls', []).size() <= 50) &&
             (data.get('imageModels', []) is list && data.get('imageModels', []).size() <= 50) &&
             (data.get('imageCaptions', []) is list && data.get('imageCaptions', []).size() <= 50) &&
             (data.get('fileNames', []) is list && data.get('fileNames', []).size() <= 50) &&
             (data.get('fileTypes', []) is list && data.get('fileTypes', []).size() <= 50) &&
             (data.get('boardId', null) == null || data.get('boardId', null) is string) &&
             (data.get('isPinned', null) == null || data.get('isPinned', null) is bool) &&
             data.keys().hasAll(['text', 'boardId', 'authorId', 'authorEmail', 'createdAt']);
    }

    function isValidSettings(data) {
      return data.ownerEmail is string &&
             data.trialDays is number &&
             data.allFree is bool &&
             data.keys().hasAll(['ownerEmail', 'trialDays', 'allFree']) &&
             data.keys().size() == 3;
    }

    function isValidLicense(data) {
      return data.email is string &&
             data.activationCode is string &&
             data.activated is bool &&
             (data.trialStartDate is number || data.trialStartDate is timestamp) &&
             data.keys().hasAll(['email', 'activationCode', 'activated', 'trialStartDate']);
    }

    // --- Collections ---
    match /user_keys/{email} {
      allow read, write: if true;
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /licenses/{licenseId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.token.email.lower() == licenseId.lower());
      allow write: if isAdmin() || (
        isSignedIn() && 
        request.auth.token.email.lower() == licenseId.lower() &&
        (
          // Allow creation of non-activated license document for self on first login
          (request.method == "create" && incoming().activated == false && incoming().email.lower() == request.auth.token.email.lower()) ||
          // Allow activation update if they entered the correct matching code
          (request.method == "update" && incoming().activated == true && existing().activated == false && incoming().activationCode == existing().activationCode && incoming().trialStartDate == existing().trialStartDate && incoming().email.lower() == existing().email.lower())
        )
      );
    }

    match /boards/{boardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /posts/{postId} {
      // Public read for the feed
      allow read: if true;

      allow create: if isAdmin() && 
                      isValidId(postId) &&
                      isValidPost(incoming()) &&
                      (!isSignedIn() || (incoming().authorId == request.auth.uid && incoming().authorEmail.lower() == request.auth.token.email.lower())) &&
                      incoming().createdAt == request.time;

      allow update: if isAdmin() && 
                      isValidId(postId) &&
                      isValidPost(incoming()) &&
                      incoming().updatedAt == request.time &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().authorId == existing().authorId;

      allow delete: if true;
    }

    match /recycle_bin/{itemId} {
      allow read, write: if isAdmin();
    }
  }
}
